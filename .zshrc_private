# This file is more personalized, but feel free to use

# Theme
ZSH_THEME="dracula-pro"

# iTerm
test -e "$HOME/.iterm2_shell_integration.zsh" && source "$HOME/.iterm2_shell_integration.zsh"

# iOS Shellfish
test -e "$HOME/.shellfishrc" && source "$HOME/.shellfishrc"

# User placed binaries
export PATH="$HOME/.local/bin:$HOME/.bin:$PATH"
if [[ $(uname) == "Linux" ]]; then
  export PATH="$HOME/.bin/linux:$PATH"
elif [[ $(uname) == "Darwin" ]]; then
  export PATH="$HOME/.bin/macos:$PATH"
fi

# usr/local/bin
export PATH="/usr/local/bin:$PATH"

# SSH
if [[ $(uname) == "Linux" && -n "${SSH_AUTH_SOCK:-}" && -r "$HOME/.ssh/id_ed25519" ]]; then
  ssh-add -l >/dev/null 2>&1 || ssh-add "$HOME/.ssh/id_ed25519"
fi

if [[ $(uname) == "Darwin" && -z "$SSH_CONNECTION" ]]; then
  export SSH_AUTH_SOCK=~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock
fi

# Git commit signing: use 1Password only for local macOS shells.
if [[ $(uname) == "Darwin" && -z "$SSH_CONNECTION" ]]; then
  git config --global gpg.ssh.program /Applications/1Password.app/Contents/MacOS/op-ssh-sign
  if [ -f "$HOME/.ssh/1password_signing_key.pub" ]; then
    git config --global user.signingkey "$HOME/.ssh/1password_signing_key.pub"
    git config --global --unset gpg.ssh.defaultKeyCommand 2>/dev/null || true
  else
    git config --global --unset user.signingkey 2>/dev/null || true
    git config --global gpg.ssh.defaultKeyCommand "ssh-add -L"
  fi
else
  git config --global gpg.ssh.program ssh-keygen
  if [ -f "$HOME/.ssh/git_signing_key.pub" ]; then
    git config --global user.signingkey "$HOME/.ssh/git_signing_key.pub"
    git config --global --unset gpg.ssh.defaultKeyCommand 2>/dev/null || true
  else
    git config --global --unset user.signingkey 2>/dev/null || true
    git config --global gpg.ssh.defaultKeyCommand "ssh-add -L"
  fi
fi

# Starship terminal
if [ -x "$(command -v starship)" ]; then
  # Starship
  export STARSHIP_CONFIG="$HOME/.config/starship/config.toml"
  eval "$(starship init zsh)"
fi
